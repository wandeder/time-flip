{
  "manifest_version": 3,
  "name": "TimeFlip",
  "version": "1.0.0",
  "description": "Unix timestamp converter with timezone support",
  "permissions": ["storage"],
  "host_permissions": [],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TimeFlip"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
